#Phase 1 - run a basic llm with a vllm

#1. Import the model
from vllm import LLM, SamplingParams
import torch, gc, time

#2. Load the model - define model and gpu memory usage
llm = LLM(
    model="facebook/opt-125m",
    gpu_memory_utilization = 0.8
)

#3. Set generation rules
sampling_params = SamplingParams(
    temperature = 0.4,
    top_p = 0.95,
    max_tokens = 20
)

#4. Send prompts and generate outputs
prompts = [
    "To be or not to be,",
    "How many endagered species are there in the world reported in 2025 as a number?",
    "What is your name?",
    "What is the biggest animal in the world?",
    "How many colours in the rainbow?"
]
output = llm.generate(prompts, sampling_params)

#5. Print outputs
for out in output:
    print("Prompt: ", out.prompt)
    print("Generated: ", out.outputs[0].text)

# CLEANUP CELL — run before recreating llm
# This clears GPU memory usage so we can run the same instance maybe with diff prompts

try:
    del llm
except NameError:
    pass

gc.collect()

if torch.cuda.is_available():
    torch.cuda.empty_cache()
    torch.cuda.ipc_collect()

print("Memory cleared as much as PyTorch allows.")


# Phase 2 - measuring current model performance for optimization goals - baseline

# Measure latency, throughouput, and GPU memory
# Start time -> llm generation -> end timer -> calculate tokens used -> calculate throughput, latency and GPU memory

#1. Start timer
start_time = time.time()

#2. Send prompts and generate outputs
output = llm.generate(prompts, sampling_params)

#3. End timer
end_time = time.time()

# Find Latency

latency = end_time - start_time
print(f"Latency: {latency: .2f}, seconds")

# Find throughput

total_generated_tokens = 0
for out in output:
    total_generated_tokens += len(out.outputs[0].token_ids)

throughput = total_generated_tokens / latency
print(f"Throughput: {throughput: .2f} tokens/sec")

